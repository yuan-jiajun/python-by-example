############################
# Frontend files (ignore)
############################
*.html
*.css
*.js

############################
# Python cache / build
############################
__pycache__/
*.py[cod]
*$py.class

############################
# Virtual environments
############################
.venv/
venv/
env/
ENV/

############################
# Environment variables
############################
.env
.env.*

############################
# Packaging / build output
############################
build/
dist/
*.egg-info/
.eggs/

############################
# Test / coverage
############################
.pytest_cache/
.coverage
.coverage.*
htmlcov/

############################
# Jupyter / notebooks
############################
.ipynb_checkpoints/

############################
# Logs
############################
*.log

############################
# OS / editor junk
############################
.DS_Store
Thumbs.db

############################
# IDEs
############################
.vscode/
.idea/
*.swp
*.swo
